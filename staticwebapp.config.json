{
  "routes": [
    {
      "route": "/api/*",
      "allowedRoles": []
    },
    {
      "route": "/*",
      "serve": "/index.html",
      "statusCode": 200
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html"
  },
  "miseHeaders": [
    {
      "path": "/*",
      "headers": [
        {
          "name": "Cache-Control",
          "value": "no-cache"
        }
      ]
    }
  ]
}
